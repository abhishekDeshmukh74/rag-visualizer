# Set to "true" to bypass the backend API and serve responses from precomputed
# static files in public/precomputed/. Useful for demos, CI, or when the
# backend is unavailable. Only works with the built-in sample documents.
VITE_USE_PRECOMPUTED=false

# Optional: override the backend URL (defaults to the Vite dev proxy at /api)
# VITE_BACKEND_URL=http://localhost:7000
